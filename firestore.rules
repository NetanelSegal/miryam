rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Participants: users can read/update own doc (id = uid), admin can read all
    match /participants/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      allow create, update: if request.auth != null
        && (request.auth.uid == userId
          || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Trivia results: authenticated read/write (one per participant)
    match /triviaResults/{doc} {
      allow read, write: if request.auth != null;
    }

    // Votes: authenticated read/write
    match /votes/{doc} {
      allow read, write: if request.auth != null;
    }

    // Costumes: authenticated create, admin read/update (review)
    match /costumes/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Blessings: public read, authenticated create
    match /blessings/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Contacts: admin read, public create
    match /contacts/{doc} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow create: if true;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Dictionary terms: public read, admin-only write
    match /dictionary/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Trivia questions: public read, admin-only write
    match /triviaQuestions/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Event settings: public read (clients need votingOpen/partyOpen), admin-only write
    match /settings/event {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Media kit: socialStats public read, admin write (no Cloud Functions)
    match /mediaKit/socialStats {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    match /mediaKit/config {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admin whitelist: admins can list/add/remove; users can read own doc to check if admin
    match /admins/{email} {
      allow read: if request.auth != null && (
        request.auth.token.email == email
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
      allow create, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      allow update: if false;
    }
  }
}
